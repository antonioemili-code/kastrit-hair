{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kastrit — The Art of Braiding, Made Accessible</title>
  <meta name="description" content="Professional hair braiding education for every woman. Instant digital access.">
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --cream:#FAF6F1;--gold:#C9A96E;--gold-light:#E8D5B0;--gold-pale:#F5ECD9;
      --terracotta:#C4714A;--dark:#1A100D;--mid:#6B5B52;--soft:#A89080;--border:#EAE0D4;
    }
    html,body{height:100%;-webkit-text-size-adjust:100%}
    body{
      font-family:'Inter',sans-serif;
      background:var(--cream);
      color:var(--dark);
      display:flex;flex-direction:column;
      align-items:center;justify-content:center;
      min-height:100vh;
      overflow:hidden;
      position:relative;
    }

    /* BACKGROUND CIRCLES */
    .bg{position:fixed;inset:0;pointer-events:none;overflow:hidden;z-index:0}
    .bg__circle{position:absolute;border-radius:50%;background:var(--gold-pale)}
    .bg__circle--1{width:60vw;height:60vw;top:-20vw;right:-20vw;opacity:.45;animation:float1 8s ease-in-out infinite}
    .bg__circle--2{width:40vw;height:40vw;bottom:-15vw;left:-10vw;opacity:.3;animation:float2 10s ease-in-out infinite}
    @keyframes float1{0%,100%{transform:translate(0,0)}50%{transform:translate(-2%,3%)}}
    @keyframes float2{0%,100%{transform:translate(0,0)}50%{transform:translate(3%,-2%)}}

    /* CONTENT */
    .page{position:relative;z-index:1;text-align:center;padding:40px 24px;display:flex;flex-direction:column;align-items:center;gap:0}

    /* LOGO */
    .logo{
      width:clamp(120px,40vw,180px);
      height:auto;
      margin-bottom:56px;
      opacity:0;
      animation:fadein .8s cubic-bezier(.22,1,.36,1) .1s forwards;
    }

    /* HEADLINE */
    .headline{
      font-family:'Cormorant Garamond',serif;
      font-size:clamp(3rem,10vw,7.5rem);
      font-weight:700;
      line-height:1.02;
      letter-spacing:-.02em;
      color:var(--dark);
      margin-bottom:12px;
      opacity:0;
      animation:slidein .9s cubic-bezier(.22,1,.36,1) .25s forwards;
    }
    .headline em{color:var(--terracotta);font-style:italic;font-weight:400}

    /* TAGLINE */
    .tagline{
      font-size:clamp(.85rem,2vw,1rem);
      color:var(--mid);
      font-weight:300;
      letter-spacing:.04em;
      max-width:380px;
      line-height:1.7;
      margin-bottom:52px;
      opacity:0;
      animation:fadein .8s cubic-bezier(.22,1,.36,1) .5s forwards;
    }

    /* CTA wrapper handles the fade-in */
    .cta-wrap{opacity:0;animation:fadein .8s cubic-bezier(.22,1,.36,1) .7s forwards}
    /* CTA handles pulse separately, after fade completes */
    .cta{
      display:inline-block;
      background:var(--dark);
      color:#fff;
      padding:15px 44px;
      font-size:.75rem;
      font-weight:500;
      letter-spacing:.18em;
      text-transform:uppercase;
      border-radius:2px;
      text-decoration:none;
      transition:background .25s,transform .2s,box-shadow .2s;
      animation:pulse-cta 3s ease-in-out 2.5s infinite;
    }
    .cta:hover{background:var(--terracotta);transform:translateY(-2px);box-shadow:0 8px 24px rgba(196,113,74,.4);animation:none}
    @keyframes pulse-cta{
      0%,100%{box-shadow:0 0 0 0 rgba(26,16,13,0)}
      50%{box-shadow:0 0 0 8px rgba(26,16,13,.07)}
    }

    /* DIVIDER LINE */
    .line{
      width:1px;height:60px;
      background:linear-gradient(to bottom,transparent,var(--gold),transparent);
      margin:48px 0;
      opacity:0;
      animation:fadein 1s ease .9s forwards;
    }

    /* BRAND NOTE */
    .note{
      font-size:.68rem;
      letter-spacing:.14em;
      text-transform:uppercase;
      color:var(--soft);
      opacity:0;
      animation:fadein .8s ease 1s forwards;
    }

    /* SCROLL HINT */
    .scroll-hint{
      position:fixed;bottom:28px;left:50%;transform:translateX(-50%);
      display:flex;flex-direction:column;align-items:center;gap:6px;
      font-size:.58rem;letter-spacing:.16em;text-transform:uppercase;color:var(--soft);
      opacity:0;animation:fadein 1s ease 1.4s forwards;
    }
    .scroll-hint__bar{width:1px;height:36px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollbar 1.8s ease-in-out infinite}
    @keyframes scrollbar{0%,100%{opacity:.3;transform:scaleY(.5)}50%{opacity:1;transform:scaleY(1)}}

    @keyframes fadein{from{opacity:0}to{opacity:1}}
    @keyframes slidein{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

    /* CONFETTI keyframe (injected by JS) */
  </style>
</head>
<body>

  <div class="bg">
    <div class="bg__circle bg__circle--1"></div>
    <div class="bg__circle bg__circle--2"></div>
  </div>

  {% assign first_product = collections.all.products.first %}

  <div class="page">
    <svg class="logo" viewBox="0 0 180 38" xmlns="http://www.w3.org/2000/svg" aria-label="Kastrit">
      <text x="0" y="30" font-family="'Cormorant Garamond', Georgia, serif" font-size="30" font-weight="700" letter-spacing="5" fill="#1A100D">KASTRIT</text>
      <circle cx="173" cy="34" r="3" fill="#C9A96E"/>
    </svg>

    <h1 class="headline">
      The Art<br>of <em>Braiding.</em>
    </h1>

    <p class="tagline">Professional techniques, beginner-friendly guide.<br>Start learning today — instantly.</p>

    {% if first_product %}
      <div class="cta-wrap">
        <a href="{{ first_product.url }}" class="cta" id="mainCta">Shop the Guide →</a>
      </div>
    {% endif %}

    <div class="line"></div>
    <span class="note">Hair Braiding Training Manual — $9.99</span>
  </div>

  <div class="scroll-hint">
    <div class="scroll-hint__bar"></div>
  </div>

  <script>
    /* CONFETTI on CTA tap/click */
    (function() {
      const COLORS = ['#C9A96E','#E8D5B0','#C4714A','#FAF6F1','#F5ECD9','#A85B38'];
      function confetti(ox, oy) {
        const s = document.createElement('style');
        s.textContent = '@keyframes cfetti{0%{opacity:1;transform:translate(-50%,-50%) scale(1) rotate(0deg)}100%{opacity:0;transform:translate(calc(-50% + var(--tx)),calc(-50% + var(--ty))) scale(.4) rotate(var(--rot))}}';
        if (!document.getElementById('cfstyle')) { s.id = 'cfstyle'; document.head.appendChild(s); }
        for (let i = 0; i < 42; i++) {
          const el = document.createElement('div');
          const size = 5 + Math.random() * 7;
          const angle = Math.random() * Math.PI * 2;
          const dist = 70 + Math.random() * 130;
          el.style.cssText = `position:fixed;left:${ox}px;top:${oy}px;width:${size}px;height:${size*(Math.random()>.5?1:2.8)}px;background:${COLORS[Math.floor(Math.random()*COLORS.length)]};border-radius:${Math.random()>.5?'50%':'2px'};pointer-events:none;z-index:9999;transform:translate(-50%,-50%);animation:cfetti .9s cubic-bezier(.22,1,.36,1) forwards;--tx:${Math.cos(angle)*dist}px;--ty:${Math.sin(angle)*dist-70}px;--rot:${Math.random()*720-360}deg`;
          document.body.appendChild(el);
          setTimeout(() => el.remove(), 950);
        }
      }
      const btn = document.getElementById('mainCta');
      if (!btn) return;
      btn.addEventListener('click', e => confetti(e.clientX, e.clientY));
      btn.addEventListener('touchstart', e => { const t = e.touches[0]; confetti(t.clientX, t.clientY); }, { passive: true });
    })();

    /* MAGNETIC (desktop only) */
    if (!window.matchMedia('(hover: none)').matches) {
      const btn = document.getElementById('mainCta');
      if (btn) {
        btn.addEventListener('mousemove', e => {
          const r = btn.getBoundingClientRect();
          btn.style.transform = `translate(${(e.clientX - r.left - r.width/2) * .22}px,${(e.clientY - r.top - r.height/2) * .22}px)`;
        });
        btn.addEventListener('mouseleave', () => btn.style.transform = '');
      }
    }
  </script>

</body>
</html>
