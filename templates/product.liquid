{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ product.title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ product.description | strip_html | truncate: 150 }}">
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --cream:#FAF6F1;
      --warm-white:#FFFDF9;
      --gold:#C9A96E;
      --gold-light:#E8D5B0;
      --gold-pale:#F5ECD9;
      --terracotta:#C4714A;
      --terra-dark:#A85B38;
      --dark:#1A100D;
      --mid:#6B5B52;
      --soft:#A89080;
      --border:#EAE0D4;
      --card-shadow:0 2px 20px rgba(30,21,18,.07);
      --card-shadow-hover:0 8px 32px rgba(30,21,18,.13);
    }
    html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
    body{font-family:'Inter',sans-serif;background:var(--warm-white);color:var(--dark);line-height:1.6;overflow-x:hidden}
    h1,h2,h3{font-family:'Cormorant Garamond',serif;line-height:1.12}
    img{max-width:100%;display:block}
    a{text-decoration:none}
    .container{max-width:860px;margin:0 auto;padding:0 20px}
    .container--wide{max-width:1080px;margin:0 auto;padding:0 20px}

    /* ── NAV ── */
    .nav{
      background:rgba(255,253,249,.96);
      border-bottom:1px solid var(--border);
      padding:14px 20px;
      position:sticky;top:0;z-index:200;
      backdrop-filter:blur(12px);
      box-shadow:0 2px 20px rgba(26,16,13,.06);
    }
    .nav__inner{max-width:1080px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .nav__logo{font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:700;letter-spacing:.12em;color:var(--dark);text-transform:uppercase;flex-shrink:0}
    .nav__cta{background:var(--dark);color:#fff;padding:9px 22px;border-radius:3px;font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;transition:background .2s;white-space:nowrap;flex-shrink:0}
    .nav__cta:hover{background:var(--terracotta)}

    /* ── SCROLL REVEAL ── */
    .reveal{opacity:0;transform:translateY(32px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1)}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── TEXT SPLIT (hero title words) ── */
    .split-word{display:inline-block;overflow:hidden;vertical-align:bottom}
    .split-word span{display:inline-block;transform:translateY(110%);transition:transform .6s cubic-bezier(.22,1,.36,1)}
    .split-word.visible span{transform:translateY(0)}

    /* ── HERO ── */
    .hero{background:var(--cream);padding:64px 20px 72px;text-align:center;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-80px;right:-80px;width:320px;height:320px;border-radius:50%;background:var(--gold-pale);opacity:.5;pointer-events:none}
    .hero::after{content:'';position:absolute;bottom:-60px;left:-60px;width:240px;height:240px;border-radius:50%;background:var(--gold-pale);opacity:.35;pointer-events:none}
    .hero__tag{display:inline-block;font-size:.65rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--terracotta);margin-bottom:16px;position:relative}
    .hero__title{font-size:clamp(2rem,7vw,3.8rem);font-weight:700;color:var(--dark);max-width:720px;margin:0 auto 18px;position:relative;line-height:1.18}
    .hero__title em{color:var(--terracotta);font-style:italic}
    .hero__sub{font-size:1rem;color:var(--mid);max-width:500px;margin:0 auto 32px;font-weight:300;line-height:1.7;position:relative}

    /* Pain block */
    .hero__pain{max-width:520px;margin:0 auto 36px;text-align:left;position:relative}
    .hero__pain p{font-size:.92rem;color:var(--mid);margin-bottom:10px;padding:10px 14px;background:rgba(255,255,255,.6);border-left:2px solid var(--gold-light);border-radius:0 4px 4px 0}
    .hero__pain-close{background:rgba(196,113,74,.06)!important;border-left-color:var(--terracotta)!important;color:var(--dark)!important;font-size:.95rem!important}

    /* Mockup */
    .hero__mockup{margin:40px auto 0;max-width:280px;position:relative;z-index:1}
    .hero__mockup img{width:100%;border-radius:8px;box-shadow:0 24px 60px rgba(30,21,18,.18),0 8px 20px rgba(30,21,18,.1)}

    /* Price card + shimmer */
    .hero__price-card{
      background:#fff;border:1px solid var(--border);border-radius:16px;
      padding:24px 28px;margin:32px auto 0;display:block;width:100%;max-width:340px;
      box-shadow:var(--card-shadow);position:relative;z-index:1;overflow:hidden;
    }
    .hero__price-card::after{
      content:'';position:absolute;inset:0;
      background:linear-gradient(110deg,transparent 30%,rgba(255,255,255,.55) 50%,transparent 70%);
      transform:translateX(-100%);
      animation:shimmer 3.5s ease-in-out 1.5s infinite;
    }
    @keyframes shimmer{
      0%{transform:translateX(-100%)}
      60%,100%{transform:translateX(150%)}
    }
    .hero__price-was{display:block;font-size:.82rem;color:var(--soft);text-decoration:line-through;letter-spacing:.04em;margin-bottom:6px}
    .hero__price-row{display:flex;align-items:baseline;justify-content:center;gap:12px;margin-bottom:10px}
    .hero__price-now{font-family:'Inter',sans-serif;font-size:2.6rem;font-weight:600;color:var(--dark);line-height:1;letter-spacing:-.02em}
    .hero__price-save{background:var(--terracotta);color:#fff;font-size:.62rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;border-radius:20px;align-self:center;flex-shrink:0}
    .hero__price-tag{display:block;font-size:.67rem;color:var(--terracotta);font-weight:600;letter-spacing:.12em;text-transform:uppercase;border-top:1px solid var(--border);padding-top:12px;margin-top:2px}

    /* CTA button + pulse */
    .btn-primary{
      display:block;width:100%;max-width:340px;margin:16px auto 0;
      background:var(--terracotta);color:#fff;padding:17px 32px;
      font-size:.82rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;
      border-radius:4px;transition:background .2s,transform .15s,box-shadow .15s;
      border:none;cursor:pointer;text-align:center;
      box-shadow:0 4px 18px rgba(196,113,74,.38);
      animation:pulse-btn 3s ease-in-out 2s infinite;
    }
    .btn-primary:hover{
      background:var(--terra-dark);transform:translateY(-2px);
      box-shadow:0 8px 28px rgba(196,113,74,.5);
      animation:none;
    }
    @keyframes pulse-btn{
      0%,100%{box-shadow:0 4px 18px rgba(196,113,74,.38)}
      50%{box-shadow:0 4px 28px rgba(196,113,74,.65),0 0 0 6px rgba(196,113,74,.1)}
    }
    .hero__lock{font-size:.73rem;color:var(--soft);margin-top:12px;display:flex;align-items:center;justify-content:center;gap:5px}

    /* Badges */
    .hero__badges{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:40px;max-width:360px;margin-left:auto;margin-right:auto;position:relative;z-index:1}
    .badge{display:flex;flex-direction:column;align-items:center;gap:6px;padding:14px 8px;background:#fff;border:1px solid var(--border);border-radius:10px}
    .badge__icon{width:34px;height:34px;border-radius:50%;background:var(--gold-pale);display:flex;align-items:center;justify-content:center;font-size:.95rem}
    .badge__label{font-size:.6rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--mid);text-align:center;line-height:1.3}

    /* ── SECTIONS ── */
    .section{padding:72px 20px}
    .section--alt{background:var(--cream)}
    .section__tag{font-size:.64rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;text-align:center;display:block}
    .section__title{font-size:clamp(1.75rem,4.5vw,2.6rem);font-weight:700;color:var(--dark);text-align:center;max-width:580px;margin:0 auto 10px}
    .section__sub{font-size:.92rem;color:var(--mid);text-align:center;max-width:480px;margin:0 auto 48px;font-weight:300;line-height:1.75}

    /* SALON BANNER + parallax */
    .salon-banner{position:relative;height:380px;overflow:hidden}
    .salon-banner__img{width:100%;height:130%;object-fit:cover;object-position:center 30%;will-change:transform;display:block}
    .salon-banner__overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(26,16,13,.7) 0%,rgba(26,16,13,.1) 60%);display:flex;align-items:flex-end;justify-content:center;padding:36px 24px}
    .salon-banner__text{font-family:'Cormorant Garamond',serif;font-size:clamp(1.1rem,3vw,1.65rem);font-style:italic;color:#fff;text-align:center;max-width:580px;line-height:1.45}

    /* INTRO */
    .intro-block{max-width:580px;margin:24px auto 0;display:flex;flex-direction:column;gap:12px}
    .intro-block p{font-size:.97rem;color:var(--mid);text-align:center;font-weight:300;line-height:1.75}

    /* LEARN GRID + tilt */
    .learn-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px}
    .learn-card{
      background:var(--warm-white);border:1px solid var(--border);border-radius:10px;
      padding:26px 22px;box-shadow:var(--card-shadow);
      transform-style:preserve-3d;transition:border-color .2s,box-shadow .2s;
      will-change:transform;
    }
    .learn-card:hover{border-color:var(--gold);box-shadow:var(--card-shadow-hover)}
    .learn-card__num{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:var(--gold-light);line-height:1;margin-bottom:10px}
    .learn-card__title{font-size:.97rem;font-weight:600;color:var(--dark);margin-bottom:6px}
    .learn-card__desc{font-size:.83rem;color:var(--mid);line-height:1.65}

    /* INCLUDED */
    .included-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
    .check-list{list-style:none;display:flex;flex-direction:column;gap:14px}
    .check-list li{display:flex;align-items:flex-start;gap:12px;font-size:.9rem;color:var(--mid)}
    .check-list li::before{content:'✦';color:var(--gold);font-size:.6rem;margin-top:5px;flex-shrink:0}
    .check-list li strong{color:var(--dark);font-weight:600}
    .details-box{background:var(--dark);color:#fff;border-radius:12px;padding:32px 28px;box-shadow:0 8px 32px rgba(26,16,13,.25)}
    .details-box__tag{font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:14px;display:block}
    .details-box__title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;margin-bottom:20px;line-height:1.2}
    .details-box__list{font-size:.82rem;color:rgba(255,255,255,.5);line-height:2}
    .details-box__list span{display:flex;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,.06);padding-bottom:2px}
    .details-box__list span:last-child{border-bottom:none}

    /* PERFECT FOR */
    .for-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;max-width:760px;margin:0 auto}
    .for-item{background:var(--warm-white);border:1px solid var(--border);border-radius:8px;padding:16px 20px;font-size:.88rem;color:var(--dark);font-weight:500;display:flex;align-items:center;gap:10px}
    .for-item::before{content:'✓';color:var(--gold);font-weight:700;flex-shrink:0}

    /* WHY DIFFERENT */
    .why-block{max-width:600px;margin:24px auto 0;display:flex;flex-direction:column;gap:14px}
    .why-block p{font-size:.97rem;color:var(--mid);font-weight:300;line-height:1.85}

    /* BONUS */
    .bonus-label{display:inline-block;background:var(--terracotta);color:#fff;font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 14px;border-radius:2px;margin-bottom:28px}
    .bonus-img{margin-bottom:36px;border-radius:12px;overflow:hidden;height:300px;box-shadow:var(--card-shadow-hover)}
    .bonus-img img{width:100%;height:100%;object-fit:cover;object-position:center}
    .bonus-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .bonus-card{
      border:1px solid var(--border);border-radius:10px;padding:22px 18px;
      text-align:center;background:var(--warm-white);box-shadow:var(--card-shadow);
      transform-style:preserve-3d;will-change:transform;transition:border-color .2s,box-shadow .2s;
    }
    .bonus-card:hover{border-color:var(--gold);box-shadow:var(--card-shadow-hover)}
    .bonus-card__icon{font-size:1.6rem;margin-bottom:10px}
    .bonus-card__title{font-size:.92rem;font-weight:600;color:var(--dark);margin-bottom:6px}
    .bonus-card__desc{font-size:.78rem;color:var(--mid);line-height:1.6}

    /* TESTIMONIALS */
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px}
    .testi-card{
      background:var(--warm-white);border:1px solid var(--border);border-radius:12px;
      padding:26px 22px;box-shadow:var(--card-shadow);
      transform-style:preserve-3d;will-change:transform;transition:border-color .2s,box-shadow .2s;
    }
    .testi-card:hover{border-color:var(--gold-light);box-shadow:var(--card-shadow-hover)}
    .testi-card__stars{color:var(--gold);font-size:.8rem;letter-spacing:2px;margin-bottom:14px}
    .testi-card__text{font-size:.88rem;color:var(--mid);line-height:1.75;margin-bottom:20px;font-style:italic}
    .testi-card__author{display:flex;align-items:center;gap:10px}
    .testi-card__avatar{width:40px;height:40px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid var(--gold-pale)}
    .testi-card__avatar img{width:100%;height:100%;object-fit:cover}
    .testi-card__name{font-weight:600;font-size:.83rem;color:var(--dark)}
    .testi-card__role{font-size:.71rem;color:var(--soft)}

    /* FAQ */
    .faq-list{max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:8px}
    .faq-item{border:1px solid var(--border);border-radius:10px;overflow:hidden;background:var(--warm-white)}
    .faq-q{width:100%;background:transparent;border:none;padding:18px 22px;text-align:left;font-family:'Inter',sans-serif;font-size:.88rem;font-weight:600;color:var(--dark);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:14px;transition:background .15s;line-height:1.4}
    .faq-q:hover{background:var(--cream)}
    .faq-icon{color:var(--gold);font-size:1.1rem;flex-shrink:0;transition:transform .25s;line-height:1}
    .faq-a{background:var(--cream);padding:0 22px;font-size:.85rem;color:var(--mid);line-height:1.8;max-height:0;overflow:hidden;transition:max-height .35s cubic-bezier(.22,1,.36,1),padding .35s cubic-bezier(.22,1,.36,1)}
    .faq-item.open .faq-a{max-height:300px;padding:16px 22px 20px}
    .faq-item.open .faq-icon{transform:rotate(45deg)}

    /* DIVIDER */
    .divider{height:1px;background:var(--border);max-width:60px;margin:0 auto}

    /* INSTANT DOWNLOAD */
    .download-block{max-width:500px;margin:22px auto 0}
    .download-block p{font-size:.97rem;color:var(--mid);font-weight:300;margin-bottom:26px;line-height:1.8;text-align:center}
    .download-pills{display:flex;justify-content:center;gap:10px;flex-wrap:wrap}
    .download-pill{background:var(--dark);color:#fff;padding:8px 20px;border-radius:100px;font-size:.76rem;font-weight:600;letter-spacing:.06em}

    /* FINAL CTA */
    .cta{background:var(--cream);padding:80px 20px;text-align:center}
    .cta__tag{font-size:.65rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--terracotta);margin-bottom:12px;display:block}
    .cta__title{font-size:clamp(1.9rem,5vw,3.2rem);font-weight:700;max-width:620px;margin:0 auto 16px}
    .cta__sub{font-size:.93rem;color:var(--mid);max-width:440px;margin:0 auto 32px;font-weight:300;line-height:1.75}
    .cta__price{display:flex;align-items:baseline;justify-content:center;gap:12px;margin-bottom:28px}
    .cta__was{font-size:1.15rem;color:var(--soft);text-decoration:line-through}
    .cta__now{font-family:'Inter',sans-serif;font-size:2.4rem;font-weight:600;color:var(--dark);line-height:1;letter-spacing:-.02em}
    .cta__btn{
      display:block;width:100%;max-width:380px;margin:0 auto;
      background:var(--terracotta);color:#fff;padding:18px 32px;
      font-size:.82rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;
      border-radius:4px;transition:background .2s,transform .15s,box-shadow .15s;
      box-shadow:0 4px 18px rgba(196,113,74,.38);text-align:center;
      animation:pulse-btn 3s ease-in-out 1s infinite;
    }
    .cta__btn:hover{background:var(--terra-dark);transform:translateY(-2px);box-shadow:0 8px 28px rgba(196,113,74,.5);animation:none}
    .cta__perks{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;margin-top:16px}
    .cta__perk{font-size:.71rem;color:var(--soft);font-weight:500;display:flex;align-items:center;gap:5px}
    .cta__perk::before{content:'✓';color:var(--gold);font-weight:700}

    /* FOOTER */
    .footer{background:var(--dark);color:rgba(255,255,255,.38);text-align:center;padding:28px 20px;font-size:.73rem}
    .footer a{color:rgba(255,255,255,.38);text-decoration:underline}

    /* FLOATING MOBILE CTA */
    .sticky-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:300;background:var(--dark);padding:12px 16px;box-shadow:0 -4px 20px rgba(0,0,0,.2);transition:opacity .3s}
    .sticky-bar__inner{display:flex;align-items:center;justify-content:space-between;gap:12px;max-width:480px;margin:0 auto}
    .sticky-bar__price{display:flex;flex-direction:column}
    .sticky-bar__was{font-size:.68rem;color:rgba(255,255,255,.4);text-decoration:line-through}
    .sticky-bar__now{font-family:'Inter',sans-serif;font-size:1.3rem;font-weight:600;color:#fff;line-height:1;letter-spacing:-.02em}
    .sticky-bar__btn{background:var(--terracotta);color:#fff;padding:11px 22px;border-radius:4px;font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;flex-shrink:0;box-shadow:0 2px 10px rgba(196,113,74,.4)}

    /* ── MOBILE ── */
    @media(max-width:768px){
      .included-grid{grid-template-columns:1fr;gap:28px}
      .bonus-grid{grid-template-columns:1fr;gap:12px}
      .learn-grid{grid-template-columns:1fr}
    }
    @media(max-width:600px){
      .hero{padding:44px 16px 56px}
      .hero::before{width:200px;height:200px;top:-60px;right:-60px}
      .hero::after{display:none}
      .hero__badges{grid-template-columns:repeat(2,1fr);max-width:260px;gap:8px}
      .hero__price-card{padding:20px 22px;border-radius:14px}
      .hero__price-now{font-size:2.2rem}
      .section{padding:56px 16px}
      .salon-banner{height:280px}
      .bonus-img{height:220px}
      .cta{padding:60px 16px 80px}
      .cta__now{font-size:2rem}
      .nav__cta{display:none}
      .sticky-bar{display:block}
      body{padding-bottom:68px}
      .testi-grid{grid-template-columns:1fr}
      .for-grid{grid-template-columns:1fr}
    }
    @media(max-width:380px){
      .hero__title{font-size:1.85rem}
      .hero__price-now{font-size:1.9rem}
      .hero__badges{max-width:220px}
    }

  </style>
</head>
<body>

  <nav class="nav" id="mainNav">
    <div class="nav__inner">
      <span class="nav__logo">Kastrit</span>
      <a href="#buy" class="nav__cta">Get Instant Access</a>
    </div>
  </nav>

  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign buy_url = '/cart/' | append: current_variant.id | append: ':1' -%}

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <span class="hero__tag reveal" data-delay="0">✦ Hair Braiding Training Manual ✦</span>
      <h1 class="hero__title" id="heroTitle">
        Learn the Art of Professional Braiding <em>Even If You're Starting From Zero</em>
      </h1>
      <p class="hero__sub reveal" data-delay="600">The practical guide that teaches you step by step how to create neat, precise, professional braids — without expensive in-person courses.</p>
      <div class="hero__pain reveal" data-delay="700">
        <p>Have you always wanted to learn how to braid perfectly but don't know where to start?</p>
        <p>Maybe you watch tutorials online that skip the most important steps.</p>
        <p>Maybe you've already tried a few styles but the result is never what you hoped for.</p>
        <p>Or maybe you want to build a skill that could one day become a paid service.</p>
        <p class="hero__pain-close"><strong>If any of this sounds like you — this guide was made for you.</strong></p>
      </div>

      <div class="hero__mockup reveal" data-delay="800">
        <img src="https://d8j0ntlcm91z4.cloudfront.net/user_3CoHflE6XwKC5XeJge3JDzQw5PH/hf_20260609_194121_d3b873f5-5fc1-4020-abd2-5beeaf109a56.png" alt="Hair Braiding Training Manual" />
      </div>

      <div class="hero__price-card reveal" data-delay="900">
        <span class="hero__price-was">Regular Price: {{ current_variant.compare_at_price | money }}</span>
        <div class="hero__price-row">
