  <script>
    /* ── 1. SCROLL REVEAL ── */
    const revealObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.transitionDelay = (e.target.dataset.delay || 0) + 'ms';
          e.target.classList.add('visible');
          revealObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

    /* ── 2. TEXT SPLIT REVEAL (hero title) ── */
    (function() {
      const title = document.getElementById('heroTitle');
      if (!title) return;
      const html = title.innerHTML;
      // wrap each word (outside <em>) in a split-word span
      const wrapped = html.replace(/(<em>.*?<\/em>|[^\s<]+)/g, (match) => {
        if (match.startsWith('<em>')) return `<span class="split-word" style="margin-right:.25em"><span>${match}</span></span>`;
        return `<span class="split-word" style="margin-right:.25em"><span>${match}</span></span>`;
      });
      title.innerHTML = wrapped;
      const words = title.querySelectorAll('.split-word');
      words.forEach((w, i) => {
        setTimeout(() => w.classList.add('visible'), 80 + i * 55);
      });
    })();

    /* ── 4. PARALLAX (salon banner) ── */
    (function() {
      const img = document.getElementById('parallaxImg');
      if (!img) return;
      function onScroll() {
        const banner = img.closest('.salon-banner');
        const rect = banner.getBoundingClientRect();
        const vh = window.innerHeight;
        if (rect.bottom < 0 || rect.top > vh) return;
        const progress = (vh - rect.top) / (vh + rect.height);
        const offset = (progress - 0.5) * 60;
        img.style.transform = `translateY(${offset}px)`;
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();

    /* ── 5. MAGNETIC BUTTON ── */
    document.querySelectorAll('.btn-primary, .cta__btn, .nav__cta').forEach(btn => {
      btn.addEventListener('mousemove', e => {
        const r = btn.getBoundingClientRect();
        const x = e.clientX - r.left - r.width / 2;
        const y = e.clientY - r.top - r.height / 2;
        btn.style.transform = `translate(${x * 0.18}px, ${y * 0.18}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });

    /* ── 6. CARD TILT 3D ── */
    document.querySelectorAll('.learn-card, .bonus-card, .testi-card').forEach(card => {
      card.addEventListener('mousemove', e => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `perspective(600px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg) translateZ(4px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });

    /* ── 7. STICKY BAR hide on CTA ── */
    (function() {
      const buySection = document.getElementById('buy');
      const stickyBar = document.getElementById('stickyBar');
      if (!buySection || !stickyBar) return;
      const obs = new IntersectionObserver(entries => {
        stickyBar.style.opacity = entries[0].isIntersecting ? '0' : '1';
        stickyBar.style.pointerEvents = entries[0].isIntersecting ? 'none' : 'auto';
      }, { threshold: 0.1 });
      obs.observe(buySection);
    })();

    /* ── FAQ accordion ── */
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item'), isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });

    /* ── MOBILE A: SECTION COLOR SHIFT ── */
    (function() {
      const sections = Array.from(document.querySelectorAll('.hero, .section, .cta'));
      const palette = [
        '#FAF6F1',
        '#FFFDF9',
        '#F5ECD9',
        '#FAF6F1',
        '#FFF8F3',
        '#FFFDF9',
        '#F7F0E8',
        '#FFFDF9',
        '#FAF6F1',
        '#FFFDF9',
        '#FAF6F1',
      ];
      document.body.style.transition = 'background-color 1s cubic-bezier(.22,1,.36,1)';
      let activeIdx = -1;
      let ticking = false;
      function update() {
        const mid = window.innerHeight / 2;
        let closest = 0, minDist = Infinity;
        sections.forEach((s, i) => {
          const r = s.getBoundingClientRect();
          const center = r.top + r.height / 2;
          const dist = Math.abs(center - mid);
          if (dist < minDist) { minDist = dist; closest = i; }
        });
        if (closest !== activeIdx) {
          activeIdx = closest;
          document.body.style.backgroundColor = palette[closest % palette.length];
        }
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
      update();
    })();

    /* ── MOBILE B: SCROLL PROGRESS BAR ── */
    (function() {
      const bar = document.createElement('div');
      bar.style.cssText = 'position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#C9A96E,#C4714A);width:0%;z-index:9999;transition:width .1s linear;pointer-events:none';
      document.body.appendChild(bar);
      window.addEventListener('scroll', () => {
        const doc = document.documentElement;
        const pct = (doc.scrollTop / (doc.scrollHeight - doc.clientHeight)) * 100;
        bar.style.width = pct + '%';
      }, { passive: true });
    })();

    /* ── MOBILE B: HAPTIC + CONFETTI DORATO sul CTA ── */
    (function() {
      const COLORS = ['#C9A96E','#E8D5B0','#C4714A','#fff','#F5ECD9','#A85B38'];
      function confetti(originX, originY) {
        const count = 38;
        for (let i = 0; i < count; i++) {
          const el = document.createElement('div');
          const size = 5 + Math.random() * 6;
          const angle = Math.random() * Math.PI * 2;
          const dist = 60 + Math.random() * 120;
          const tx = Math.cos(angle) * dist;
          const ty = Math.sin(angle) * dist - 60;
          const rot = Math.random() * 720 - 360;
          const shape = Math.random() > 0.5 ? '50%' : '2px';
          el.style.cssText = `
            position:fixed;
            left:${originX}px;top:${originY}px;
            width:${size}px;height:${size * (Math.random() > 0.5 ? 1 : 2.5)}px;
            background:${COLORS[Math.floor(Math.random() * COLORS.length)]};
            border-radius:${shape};
            pointer-events:none;z-index:9998;
            transform:translate(-50%,-50%);
            animation:cfetti .8s cubic-bezier(.22,1,.36,1) forwards;
            --tx:${tx}px;--ty:${ty}px;--rot:${rot}deg;
          `;
          document.body.appendChild(el);
          setTimeout(() => el.remove(), 900);
        }
      }

      if (!document.getElementById('cfettiStyle')) {
        const s = document.createElement('style');
        s.id = 'cfettiStyle';
        s.textContent = `
          @keyframes cfetti {
            0%   { opacity:1; transform:translate(-50%,-50%) scale(1) rotate(0deg) }
            100% { opacity:0; transform:translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(.4) rotate(var(--rot)) }
          }
        `;
        document.head.appendChild(s);
      }

      document.querySelectorAll('.btn-primary, .cta__btn, .sticky-bar__btn').forEach(btn => {
        btn.addEventListener('click', e => {
          const r = btn.getBoundingClientRect();
          confetti(e.clientX || r.left + r.width / 2, e.clientY || r.top + r.height / 2);
        });
        btn.addEventListener('touchstart', e => {
          const t = e.touches[0];
          confetti(t.clientX, t.clientY);
        }, { passive: true });
      });
    })();
  </script>

