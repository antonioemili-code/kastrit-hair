{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ product.title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ product.description | strip_html | truncate: 150 }}">
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --cream:#FAF6F1;--warm-white:#FFFDF9;--gold:#C9A96E;--gold-light:#E8D5B0;
      --terracotta:#C4714A;--dark:#1E1512;--mid:#6B5B52;--soft:#A89080;--border:#EDE3D8;
    }
    html{scroll-behavior:smooth}
    body{font-family:'Inter',sans-serif;background:var(--warm-white);color:var(--dark);line-height:1.6;overflow-x:hidden}
    h1,h2,h3{font-family:'Cormorant Garamond',serif;line-height:1.15}
    img{max-width:100%;display:block}
    a{text-decoration:none}
    .container{max-width:900px;margin:0 auto;padding:0 24px}
    .container--wide{max-width:1100px;margin:0 auto;padding:0 24px}

    /* NAV */
    .nav{background:var(--warm-white);border-bottom:1px solid var(--border);padding:16px 24px;position:sticky;top:0;z-index:100}
    .nav__inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between}
    .nav__logo{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;letter-spacing:.1em;color:var(--dark);text-transform:uppercase}
    .nav__cta{background:var(--dark);color:#fff;padding:9px 20px;border-radius:2px;font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;transition:background .2s}
    .nav__cta:hover{background:var(--terracotta)}

    /* HERO */
    .hero{background:var(--cream);padding:80px 24px 70px;text-align:center;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-100px;right:-100px;width:380px;height:380px;border-radius:50%;background:var(--gold-light);opacity:.2;pointer-events:none}
    .hero__tag{display:inline-block;font-size:.68rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--terracotta);margin-bottom:18px}
    .hero__title{font-size:clamp(2.4rem,6vw,4.2rem);font-weight:700;color:var(--dark);max-width:760px;margin:0 auto 20px}
    .hero__title em{color:var(--terracotta);font-style:italic}
    .hero__sub{font-size:1.05rem;color:var(--mid);max-width:520px;margin:0 auto 36px;font-weight:300}
    .hero__price{display:inline-flex;flex-direction:column;align-items:center;gap:4px;margin-bottom:32px}
    .hero__price-was{font-size:.95rem;color:var(--soft);text-decoration:line-through}
    .hero__price-now{font-family:'Cormorant Garamond',serif;font-size:3.4rem;font-weight:700;color:var(--dark);line-height:1}
    .hero__price-tag{font-size:.68rem;color:var(--terracotta);font-weight:600;letter-spacing:.1em;text-transform:uppercase}
    .btn-primary{display:inline-block;background:var(--terracotta);color:#fff;padding:16px 48px;font-size:.85rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;border-radius:2px;transition:background .2s,transform .15s;border:none;cursor:pointer}
    .btn-primary:hover{background:#b05e3a;transform:translateY(-1px)}
    .hero__lock{font-size:.75rem;color:var(--soft);margin-top:14px;display:flex;align-items:center;justify-content:center;gap:6px}
    .hero__badges{display:flex;justify-content:center;gap:28px;margin-top:50px;flex-wrap:wrap}
    .badge{display:flex;flex-direction:column;align-items:center;gap:5px}
    .badge__icon{width:38px;height:38px;border-radius:50%;background:var(--gold-light);display:flex;align-items:center;justify-content:center;font-size:1rem}
    .badge__label{font-size:.68rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--mid)}

    /* SECTIONS */
    .section{padding:80px 24px}
    .section--alt{background:var(--cream)}
    .section__tag{font-size:.68rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;text-align:center}
    .section__title{font-size:clamp(1.9rem,4vw,2.8rem);font-weight:700;color:var(--dark);text-align:center;max-width:620px;margin:0 auto 12px}
    .section__sub{font-size:.95rem;color:var(--mid);text-align:center;max-width:500px;margin:0 auto 52px;font-weight:300}

    /* LEARN GRID */
    .learn-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:20px}
    .learn-card{background:var(--warm-white);border:1px solid var(--border);border-radius:4px;padding:28px 24px;transition:border-color .2s,transform .2s}
    .learn-card:hover{border-color:var(--gold);transform:translateY(-2px)}
    .learn-card__num{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;color:var(--gold-light);line-height:1;margin-bottom:10px}
    .learn-card__title{font-size:1rem;font-weight:600;color:var(--dark);margin-bottom:6px}
    .learn-card__desc{font-size:.84rem;color:var(--mid);line-height:1.6}

    /* INCLUDED */
    .included-grid{display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:start}
    @media(max-width:680px){.included-grid{grid-template-columns:1fr;gap:36px}}
    .check-list{list-style:none;display:flex;flex-direction:column;gap:16px}
    .check-list li{display:flex;align-items:flex-start;gap:12px;font-size:.92rem;color:var(--mid)}
    .check-list li::before{content:'✦';color:var(--gold);font-size:.65rem;margin-top:4px;flex-shrink:0}
    .check-list li strong{color:var(--dark);font-weight:600}
    .details-box{background:var(--dark);color:#fff;border-radius:4px;padding:36px 32px}
    .details-box__tag{font-size:.64rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:16px}
    .details-box__title{font-size:1.75rem;font-weight:700;margin-bottom:20px}
    .details-box__list{font-size:.82rem;color:rgba(255,255,255,.5);line-height:1.9}
    .details-box__list span{display:block}

    /* BONUS */
    .bonus-label{display:inline-block;background:var(--terracotta);color:#fff;font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 12px;border-radius:2px;margin-bottom:32px}
    .bonus-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
    @media(max-width:680px){.bonus-grid{grid-template-columns:1fr}}
    .bonus-card{border:1px solid var(--border);border-radius:4px;padding:24px 20px;text-align:center;background:var(--warm-white)}
    .bonus-card__icon{font-size:1.8rem;margin-bottom:12px}
    .bonus-card__title{font-size:.95rem;font-weight:600;color:var(--dark);margin-bottom:6px}
    .bonus-card__desc{font-size:.8rem;color:var(--mid)}

    /* PLR BANNER */
    .plr{background:linear-gradient(135deg,var(--dark) 0%,#3a2a22 100%);color:#fff;padding:64px 24px;text-align:center}
    .plr__tag{font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:14px}
    .plr__title{font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;max-width:620px;margin:0 auto 14px}
    .plr__sub{font-size:.95rem;color:rgba(255,255,255,.6);max-width:500px;margin:0 auto 36px;font-weight:300}
    .plr-pills{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
    .plr-pill{border:1px solid rgba(201,169,110,.35);color:var(--gold-light);padding:7px 18px;border-radius:100px;font-size:.77rem;font-weight:500}

    /* TESTIMONIALS */
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
    .testi-card{background:var(--warm-white);border:1px solid var(--border);border-radius:4px;padding:28px 24px}
    .testi-card__stars{color:var(--gold);font-size:.82rem;letter-spacing:2px;margin-bottom:14px}
    .testi-card__text{font-size:.9rem;color:var(--mid);line-height:1.7;margin-bottom:20px;font-style:italic}
    .testi-card__author{display:flex;align-items:center;gap:10px}
    .testi-card__avatar{width:38px;height:38px;border-radius:50%;background:var(--gold-light);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:700;color:var(--dark)}
    .testi-card__name{font-weight:600;font-size:.84rem;color:var(--dark)}
    .testi-card__role{font-size:.73rem;color:var(--soft)}

    /* FAQ */
    .faq-list{max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:2px}
    .faq-item{border:1px solid var(--border);border-radius:4px;overflow:hidden}
    .faq-q{width:100%;background:var(--warm-white);border:none;padding:20px 24px;text-align:left;font-family:'Inter',sans-serif;font-size:.9rem;font-weight:600;color:var(--dark);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:14px;transition:background .15s}
    .faq-q:hover{background:var(--cream)}
    .faq-icon{color:var(--gold);font-size:1.1rem;flex-shrink:0;transition:transform .25s}
    .faq-a{background:var(--cream);padding:0 24px;font-size:.87rem;color:var(--mid);line-height:1.75;max-height:0;overflow:hidden;transition:max-height .3s ease,padding .3s ease}
    .faq-item.open .faq-a{max-height:300px;padding:18px 24px 22px}
    .faq-item.open .faq-icon{transform:rotate(45deg)}

    /* FINAL CTA */
    .cta{background:var(--cream);padding:90px 24px;text-align:center}
    .cta__tag{font-size:.68rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--terracotta);margin-bottom:14px}
    .cta__title{font-size:clamp(2rem,5vw,3.4rem);font-weight:700;max-width:660px;margin:0 auto 18px}
    .cta__sub{font-size:.95rem;color:var(--mid);max-width:460px;margin:0 auto 36px;font-weight:300}
    .cta__price{display:flex;align-items:baseline;justify-content:center;gap:12px;margin-bottom:32px}
    .cta__was{font-size:1.2rem;color:var(--soft);text-decoration:line-through}
    .cta__now{font-family:'Cormorant Garamond',serif;font-size:3.8rem;font-weight:700;color:var(--dark);line-height:1}
    .cta__perks{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-top:14px}
    .cta__perk{font-size:.73rem;color:var(--soft);font-weight:500;display:flex;align-items:center;gap:5px}
    .cta__perk::before{content:'✓';color:var(--gold);font-weight:700}

    /* FOOTER */
    .footer{background:var(--dark);color:rgba(255,255,255,.4);text-align:center;padding:28px 24px;font-size:.75rem}
    .footer a{color:rgba(255,255,255,.4);text-decoration:underline}

    .divider{height:1px;background:var(--border);max-width:70px;margin:0 auto}

    @media(max-width:600px){
      .hero{padding:56px 18px 52px}
      .section{padding:60px 18px}
      .hero__badges{gap:18px}
      .nav__cta{display:none}
    }
  </style>
</head>
